# Development Overrides
SPRING_PROFILES_ACTIVE=dev
INFRA_HOST=100.72.208.15

# Host Access (Internal Docker Network)
# Using direct container-to-container communication on 'am-net'
KAFKA_BOOTSTRAP_SERVERS=am_kafka:9092

# MongoDB URIs for different services
# MongoDB Connection Strings:
# - For Docker containers: Use 'am_mongodb:27017' (internal Docker network)
# - For local development: Use '127.0.0.1:27018' (host machine)
MONGODB_CONNECTION_URL=mongodb://admin:password123@am_mongodb:27017/analysis?authSource=admin
# For local development (outside Docker), use:
# MONGODB_CONNECTION_URL=mongodb://admin:password123@127.0.0.1:27018/analysis?authSource=admin
DOCKER_HOSTNAME=host.docker.internal
MARKET_DATA_URL=http://${DOCKER_HOSTNAME}:8092