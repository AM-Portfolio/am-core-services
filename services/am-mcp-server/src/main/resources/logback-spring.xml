<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Log to file to keep standard output clear for the MCP STDIO transport -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>am-mcp-server.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>am-mcp-server.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Configure Spring to route standard error logs if necessary, but strictly no stdout -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <!-- Minimal pattern for stderr to avoid Logback error while keeping stdout for MCP -->
            <pattern>%d{HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="FILE" />
        <appender-ref ref="STDERR" />
    </root>

    <logger name="com.am.mcp" level="DEBUG" />
    <logger name="org.springframework.ai.mcp" level="INFO" />
</configuration>
