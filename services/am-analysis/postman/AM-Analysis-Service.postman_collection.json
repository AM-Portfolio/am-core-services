{
    "info": {
        "_postman_id": "am-analysis-service-v1",
        "name": "AM Analysis Service",
        "description": "Comprehensive API collection for AM Analysis Service endpoints. Provides portfolio dashboard, allocation, performance tracking, top movers, and recent activity.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{auth_token}}",
                "type": "string"
            }
        ]
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8090",
            "type": "string"
        },
        {
            "key": "auth_token",
            "value": "your-jwt-token-here",
            "type": "string"
        },
        {
            "key": "portfolio_id",
            "value": "sample-portfolio-id",
            "type": "string"
        },
        {
            "key": "basket_id",
            "value": "sample-basket-id",
            "type": "string"
        },
        {
            "key": "user_id",
            "value": "user-123",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Dashboard",
            "description": "Endpoints powering the main Dashboard UI",
            "item": [
                {
                    "name": "Get Dashboard Summary",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/analysis/dashboard/summary?userId={{user_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "analysis",
                                "dashboard",
                                "summary"
                            ],
                            "query": [
                                {
                                    "key": "userId",
                                    "value": "{{user_id}}"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Portfolio Overviews",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/analysis/dashboard/portfolio-overviews?userId={{user_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "analysis",
                                "dashboard",
                                "portfolio-overviews"
                            ],
                            "query": [
                                {
                                    "key": "userId",
                                    "value": "{{user_id}}"
                                },
                                {
                                    "key": "portfolioId",
                                    "value": "{{portfolio_id}}",
                                    "disabled": true
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Recent Activity",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/analysis/dashboard/recent-activity?userId={{user_id}}&page=0&size=20&sortBy=TIMESTAMP",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "analysis",
                                "dashboard",
                                "recent-activity"
                            ],
                            "query": [
                                {
                                    "key": "userId",
                                    "value": "{{user_id}}"
                                },
                                {
                                    "key": "page",
                                    "value": "0"
                                },
                                {
                                    "key": "size",
                                    "value": "20"
                                },
                                {
                                    "key": "sortBy",
                                    "value": "TIMESTAMP",
                                    "description": "e.g., TIMESTAMP, PROFIT_LOSS"
                                },
                                {
                                    "key": "status",
                                    "value": "WIN",
                                    "description": "WIN, LOSS, NEUTRAL",
                                    "disabled": true
                                },
                                {
                                    "key": "type",
                                    "value": "TRADE",
                                    "disabled": true
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Publish Dashboard Update (Internal)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/analysis/dashboard/publish-update?userId={{user_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "analysis",
                                "dashboard",
                                "publish-update"
                            ],
                            "query": [
                                {
                                    "key": "userId",
                                    "value": "{{user_id}}"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Allocation Analysis",
            "description": "Endpoints for retrieving asset allocation data by sector and asset class",
            "item": [
                {
                    "name": "Get Portfolio Allocation",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/analysis/portfolio/{{portfolio_id}}/allocation",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "analysis",
                                "portfolio",
                                "{{portfolio_id}}",
                                "allocation"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Basket Allocation",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/analysis/basket/{{basket_id}}/allocation",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "analysis",
                                "basket",
                                "{{basket_id}}",
                                "allocation"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Performance Analysis",
            "description": "Endpoints for tracking portfolio and basket performance over various time frames",
            "item": [
                {
                    "name": "Get Dashboard Performance",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/analysis/dashboard/performance?userId={{user_id}}&timeFrame=1M",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "analysis",
                                "dashboard",
                                "performance"
                            ],
                            "query": [
                                {
                                    "key": "userId",
                                    "value": "{{user_id}}"
                                },
                                {
                                    "key": "timeFrame",
                                    "value": "1M"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Portfolio Performance",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/analysis/portfolio/{{portfolio_id}}/performance?timeFrame=1M",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "analysis",
                                "portfolio",
                                "{{portfolio_id}}",
                                "performance"
                            ],
                            "query": [
                                {
                                    "key": "timeFrame",
                                    "value": "1M"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Top Movers Analysis",
            "description": "Endpoints for identifying top gainers and losers",
            "item": [
                {
                    "name": "Get Dashboard Top Movers",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/analysis/dashboard/top-movers?userId={{user_id}}&timeFrame=1D",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "analysis",
                                "dashboard",
                                "top-movers"
                            ],
                            "query": [
                                {
                                    "key": "userId",
                                    "value": "{{user_id}}"
                                },
                                {
                                    "key": "timeFrame",
                                    "value": "1D",
                                    "description": "Options: 1D, 1W, 1M, YTD"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Category Top Movers (Portfolio)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/analysis/portfolio/top-movers?timeFrame=1D",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "analysis",
                                "portfolio",
                                "top-movers"
                            ],
                            "query": [
                                {
                                    "key": "timeFrame",
                                    "value": "1D"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Entity Top Movers (Portfolio)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/analysis/portfolio/{{portfolio_id}}/top-movers?timeFrame=1D",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "analysis",
                                "portfolio",
                                "{{portfolio_id}}",
                                "top-movers"
                            ],
                            "query": [
                                {
                                    "key": "timeFrame",
                                    "value": "1D"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Health Check",
            "item": [
                {
                    "name": "Health Check",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/actuator/health",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "actuator",
                                "health"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}