{
  "info": {
    "_postman_id": "am-analysis-collection",
    "name": "AM Analysis Service",
    "description": "Full API collection for am-analysis service.\n\nBase path: /api/v1/analysis\n\nIncludes:\n- Dashboard endpoints (summary, overviews, performance, top movers, recent activity)\n- Entity-level endpoints (allocation, performance, top movers by type & id)\n\nSelect an environment from the Environment dropdown:\n- **Local**: Direct local service on port 8080\n- **Dev**: dev.am.asrax.in\n- **Preprod**: am.asrax.in\n- **Prod**: am.munish.org",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health & Infra",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{analysis_url}}/actuator/health",
              "host": ["{{analysis_url}}"],
              "path": ["actuator", "health"]
            }
          }
        },
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{analysis_url}}/swagger-ui/index.html",
              "host": ["{{analysis_url}}"],
              "path": ["swagger-ui", "index.html"]
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Summary",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{analysis_url}}/api/v1/analysis/dashboard/summary?userId={{user_id}}",
              "host": ["{{analysis_url}}"],
              "path": ["api", "v1", "analysis", "dashboard", "summary"],
              "query": [{ "key": "userId", "value": "{{user_id}}" }]
            },
            "description": "Returns the top-level dashboard summary for a user (total invested, current value, P&L etc.)."
          }
        },
        {
          "name": "Get Portfolio Overviews",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{analysis_url}}/api/v1/analysis/dashboard/portfolio-overviews?userId={{user_id}}",
              "host": ["{{analysis_url}}"],
              "path": ["api", "v1", "analysis", "dashboard", "portfolio-overviews"],
              "query": [
                { "key": "userId", "value": "{{user_id}}" },
                { "key": "portfolioId", "value": "", "disabled": true, "description": "Optional. Filter to a single portfolio." }
              ]
            },
            "description": "Returns one overview card per portfolio. Omit portfolioId to get all portfolios."
          }
        },
        {
          "name": "Get Portfolio Overviews (Single Portfolio)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{analysis_url}}/api/v1/analysis/dashboard/portfolio-overviews?userId={{user_id}}&portfolioId={{portfolio_id}}",
              "host": ["{{analysis_url}}"],
              "path": ["api", "v1", "analysis", "dashboard", "portfolio-overviews"],
              "query": [
                { "key": "userId", "value": "{{user_id}}" },
                { "key": "portfolioId", "value": "{{portfolio_id}}" }
              ]
            }
          }
        },
        {
          "name": "Dashboard - Top Movers (All Portfolios)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{analysis_url}}/api/v1/analysis/dashboard/top-movers?userId={{user_id}}&timeFrame=1D",
              "host": ["{{analysis_url}}"],
              "path": ["api", "v1", "analysis", "dashboard", "top-movers"],
              "query": [
                { "key": "userId", "value": "{{user_id}}" },
                { "key": "timeFrame", "value": "1D", "description": "Options: 1D, 1W, 1M, 3M, 6M, 1Y, ALL" }
              ]
            }
          }
        },
        {
          "name": "Dashboard - Performance",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{analysis_url}}/api/v1/analysis/dashboard/performance?userId={{user_id}}&timeFrame=1M",
              "host": ["{{analysis_url}}"],
              "path": ["api", "v1", "analysis", "dashboard", "performance"],
              "query": [
                { "key": "userId", "value": "{{user_id}}" },
                { "key": "timeFrame", "value": "1M", "description": "Options: 1D, 1W, 1M, 3M, 6M, 1Y, ALL" }
              ]
            }
          }
        },
        {
          "name": "Dashboard - Recent Activity",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{analysis_url}}/api/v1/analysis/dashboard/recent-activity?userId={{user_id}}&page=0&size=20",
              "host": ["{{analysis_url}}"],
              "path": ["api", "v1", "analysis", "dashboard", "recent-activity"],
              "query": [
                { "key": "userId", "value": "{{user_id}}" },
                { "key": "type", "value": "", "disabled": true, "description": "Optional: trade type filter" },
                { "key": "status", "value": "", "disabled": true, "description": "Optional: WIN, LOSS, NEUTRAL" },
                { "key": "sector", "value": "", "disabled": true, "description": "Optional: sector name" },
                { "key": "portfolioName", "value": "", "disabled": true, "description": "Optional: portfolio name filter" },
                { "key": "sortBy", "value": "TIMESTAMP", "description": "Options: TIMESTAMP, PROFIT_LOSS" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "Paginated, filterable recent activity feed. Supports filters: type, status (WIN/LOSS/NEUTRAL), sector, portfolioName, sortBy."
          }
        },
        {
          "name": "Publish Dashboard Update (Manual Trigger)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{analysis_url}}/api/v1/analysis/dashboard/publish-update?userId={{user_id}}",
              "host": ["{{analysis_url}}"],
              "path": ["api", "v1", "analysis", "dashboard", "publish-update"],
              "query": [{ "key": "userId", "value": "{{user_id}}" }]
            },
            "description": "Manually trigger a dashboard recalculation and publish to WebSocket subscribers."
          }
        }
      ]
    },
    {
      "name": "Entity Analysis",
      "description": "Entity-level endpoints. {type} can be: PORTFOLIO, HOLDING, STOCK",
      "item": [
        {
          "name": "Get Allocation (Portfolio)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "groupBy", "value": "STOCK", "description": "Optional: STOCK or SECTOR" }
            ],
            "url": {
              "raw": "{{analysis_url}}/api/v1/analysis/portfolio/{{portfolio_id}}/allocation?groupBy=STOCK",
              "host": ["{{analysis_url}}"],
              "path": ["api", "v1", "analysis", "portfolio", "{{portfolio_id}}", "allocation"],
              "query": [{ "key": "groupBy", "value": "STOCK", "description": "Options: STOCK, SECTOR" }]
            },
            "description": "Get allocation breakdown for a specific portfolio. type=portfolio | stock | holding"
          }
        },
        {
          "name": "Get Allocation (Sector Grouped)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{analysis_url}}/api/v1/analysis/portfolio/{{portfolio_id}}/allocation?groupBy=SECTOR",
              "host": ["{{analysis_url}}"],
              "path": ["api", "v1", "analysis", "portfolio", "{{portfolio_id}}", "allocation"],
              "query": [{ "key": "groupBy", "value": "SECTOR" }]
            }
          }
        },
        {
          "name": "Get Performance (Portfolio)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{analysis_url}}/api/v1/analysis/portfolio/{{portfolio_id}}/performance?timeFrame=1M",
              "host": ["{{analysis_url}}"],
              "path": ["api", "v1", "analysis", "portfolio", "{{portfolio_id}}", "performance"],
              "query": [{ "key": "timeFrame", "value": "1M", "description": "Options: 1D, 1W, 1M, 3M, 6M, 1Y, ALL" }]
            }
          }
        },
        {
          "name": "Get Top Movers (By Entity Type)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{analysis_url}}/api/v1/analysis/portfolio/top-movers?timeFrame=1D&groupBy=STOCK",
              "host": ["{{analysis_url}}"],
              "path": ["api", "v1", "analysis", "portfolio", "top-movers"],
              "query": [
                { "key": "timeFrame", "value": "1D" },
                { "key": "groupBy", "value": "STOCK" }
              ]
            },
            "description": "Top movers across all entities of a given type."
          }
        },
        {
          "name": "Get Top Movers (Specific Portfolio)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{analysis_url}}/api/v1/analysis/portfolio/{{portfolio_id}}/top-movers?timeFrame=1D&groupBy=STOCK",
              "host": ["{{analysis_url}}"],
              "path": ["api", "v1", "analysis", "portfolio", "{{portfolio_id}}", "top-movers"],
              "query": [
                { "key": "timeFrame", "value": "1D" },
                { "key": "groupBy", "value": "STOCK" }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "description": "Override per environment"
    },
    {
      "key": "jwt_token",
      "value": "paste-your-token-here"
    },
    {
      "key": "user_id",
      "value": "ssd2658"
    },
    {
      "key": "portfolio_id",
      "value": "163d0143-4fcb-480c-ac20-622f14e0e293"
    }
  ]
}
