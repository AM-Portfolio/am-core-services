{
  "id": "am-core-services-environment",
  "name": "AM Core Services",
  "_postman_variable_scope": "environment",
  "values": [
    {
      "key": "env",
      "value": "local",
      "type": "default",
      "enabled": true,
      "description": "Active environment. Options: local | dev | preprod. Update base_url below to match."
    },
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "default",
      "enabled": true,
      "description": "Set to the URL for your chosen environment:\n  local   → http://localhost:8080\n  dev     → https://dev.am.asrax.in\n  preprod → https://am.asrax.in"
    },
    {
      "key": "ws_url",
      "value": "ws://localhost:8080",
      "type": "default",
      "enabled": true,
      "description": "WebSocket URL for am-gateway.\n  local   → ws://localhost:8080\n  dev     → wss://dev.am.asrax.in\n  preprod → wss://am.asrax.in"
    },
    {
      "key": "base_url_local",
      "value": "http://localhost:8080",
      "type": "default",
      "enabled": true,
      "description": "Local environment base URL."
    },
    {
      "key": "base_url_dev",
      "value": "https://dev.am.asrax.in",
      "type": "default",
      "enabled": true,
      "description": "Dev environment base URL."
    },
    {
      "key": "base_url_preprod",
      "value": "https://am.asrax.in",
      "type": "default",
      "enabled": true,
      "description": "Preprod environment base URL (primary active environment)."
    },
    {
      "key": "analysis_url",
      "value": "{{base_url}}/analysis",
      "type": "default",
      "enabled": true,
      "description": "Base URL for Analysis service."
    },
    {
      "key": "mcp_url",
      "value": "{{base_url}}/mcp",
      "type": "default",
      "enabled": true,
      "description": "Base URL for MCP server."
    },
    {
      "key": "gateway_url",
      "value": "{{base_url}}",
      "type": "default",
      "enabled": true,
      "description": "Base URL for Gateway service (note: health is at root, ws is at /ws-gateway-raw)."
    },
    {
      "key": "jwt_token",
      "value": "paste-your-token-here",
      "type": "secret",
      "enabled": true,
      "description": "Bearer JWT token. Obtain from: POST /auth/token/v1/login"
    },
    {
      "key": "user_id",
      "value": "ssd2658",
      "type": "default",
      "enabled": true,
      "description": "Default user ID for API requests."
    },
    {
      "key": "portfolio_id",
      "value": "163d0143-4fcb-480c-ac20-622f14e0e293",
      "type": "default",
      "enabled": true,
      "description": "Default portfolio UUID."
    }
  ]
}
